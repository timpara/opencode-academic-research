{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],
  "compaction": {
    "auto": true,
    "prune": false,
    "reserved": 12000
  },
  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "edit": "allow",
    "skill": "allow",
    "webfetch": "allow",
    "todowrite": "allow",
    "bash": {
      "uv *": "allow",
      "uv run *": "allow",
      "python3 scripts/*": "allow",
      "python scripts/*": "allow",
      "pytest *": "allow",
      "ruff *": "allow",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "ls *": "allow",
      "find *_agent.md*": "allow",
      "bun *": "allow",
      "pandoc *": "ask",
      "tectonic *": "ask",
      "*": "ask"
    }
  },
  "agent": {
    "build": {
      "permission": {
        "bash": {
          "uv run python3 scripts/*": "allow",
          "uv run pytest*": "allow",
          "uv run ruff*": "allow",
          "*": "ask"
        }
      }
    }
  }
}
